# ==============================
# Application
# ==============================
APP_NAME="Estimation Immobilier Lannion"
APP_BASE_URL="https://estimation-immobilier-lannion.fr"
WEBSITE_ID=2

# ==============================
# Base de données (MySQL / MariaDB)
# ==============================
DB_HOST="localhost"
DB_PORT="3306"
DB_NAME="cool1933_esti-mmo-lannion"
DB_USER="cool1933_esti-immo-lannion-user"
DB_PASS=""
DB_CHARSET="utf8mb4"

# ==============================
# Admin
# ==============================
ADMIN_EMAIL="contact@estimation-immobilier-lannion.fr"
ADMIN_PASSWORD=""

# ==============================
# Perplexity AI
# ==============================
PERPLEXITY_API_KEY=""
PERPLEXITY_MODEL="sonar-pro"
PERPLEXITY_ENDPOINT="https://api.perplexity.ai/chat/completions"

# ==============================
# OpenAI
# ==============================
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_ENDPOINT="https://api.openai.com/v1/chat/completions"

# ==============================
# Email / SMTP (Sortant)
# Les deux formats sont acceptes :
#   MAIL_SMTP_HOST ou MAIL_HOST
#   MAIL_SMTP_PORT ou MAIL_PORT
#   MAIL_SMTP_USER ou MAIL_USERNAME
#   MAIL_SMTP_PASS ou MAIL_PASSWORD
#   MAIL_SMTP_ENCRYPTION ou MAIL_ENCRYPTION
#   MAIL_FROM ou MAIL_FROM_ADDRESS
#
# IMPORTANT (o2switch / hebergement mutualise) :
#   - MAIL_FROM doit correspondre au MAIL_USERNAME pour l'alignement SPF
#   - Configurez SPF et DKIM dans votre zone DNS (cPanel > Email Deliverability)
#   - Doc : https://faq.o2switch.fr/hebergement-mutualise/tutoriels-cpanel/authentification-email-spf-dkim
# ==============================
MAIL_DRIVER="smtp"
MAIL_FROM="no-reply@estimation-immobilier-lannion.fr"
MAIL_FROM_ADDRESS="contact@estimation-immobilier-lannion.fr"
MAIL_FROM_NAME="Estimation Immobilier Lannion"
MAIL_HOST="bus.o2switch.net"
MAIL_PORT="465"
MAIL_USERNAME="contact@estimation-immobilier-lannion.fr"
MAIL_PASSWORD=""
MAIL_ENCRYPTION="ssl"

# ==============================
# IMAP Configuration (Entrant)
# ==============================
IMAP_HOST="bus.o2switch.net"
IMAP_PORT="993"
IMAP_USERNAME="contact@estimation-immobilier-lannion.fr"
IMAP_PASSWORD=""
IMAP_ENCRYPTION="ssl"

# ==============================
# POP3 Configuration (Alternative entrant)
# ==============================
POP3_HOST="estimation-immobilier-lannion.fr"
POP3_PORT="995"
POP3_USERNAME="contact@estimation-immobilier-lannion.fr"
POP3_PASSWORD=""
POP3_ENCRYPTION="ssl"

# ==============================
# Couleurs du site
# ==============================
SITE_COLOR_BG="#faf9f7"
SITE_COLOR_SURFACE="#ffffff"
SITE_COLOR_TEXT="#1a1410"
SITE_COLOR_MUTED="#6b6459"
SITE_COLOR_PRIMARY="#0D47A1"
SITE_COLOR_PRIMARY_DARK="#0A3570"
SITE_COLOR_ACCENT="#00BFA5"
SITE_COLOR_ACCENT_LIGHT="#1DE9B6"
SITE_COLOR_BORDER="#e8dfd7"
SITE_COLOR_SUCCESS="#22c55e"
SITE_COLOR_WARNING="#f97316"
SITE_COLOR_DANGER="#e24b4a"
SITE_COLOR_INFO="#3b82f6"
SITE_COLOR_NEUTRAL="#000000"

# ==============================
# Claude (Anthropic)
# ==============================
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ==============================
# Google Maps Places
# ==============================
GOOGLE_MAPS_API_KEY=""

# ==============================
# SMS Partner
# ==============================
SMSPARTNER_API_KEY=""

# ==============================
# Twilio
# ==============================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ==============================
# Développement
# ==============================
# Passer à true pour accéder au dashboard sans login
DEV_SKIP_AUTH=false

# ==============================
# Maintenance
# ==============================
MAINTENANCE_MODE=false
MAINTENANCE_RETRY_AFTER=3600
